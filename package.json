{
  "name": "secureclaw",
  "private": true,
  "version": "0.1.0",
  "description": "Your secure personal AI agent. Defense in depth. Zero trust by default.",
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "build": "pnpm -r build",
    "test": "pnpm -r test",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "dev": "docker compose -f docker-compose.dev.yml up",
    "proto:gen": "node scripts/proto-gen.mjs",
    "certs:gen": "bash scripts/gen-certs.sh",
    "preinstall": "npx only-allow pnpm"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^9.0.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "dependencies": {
    "pnpm": "^10.30.2"
  }
}
