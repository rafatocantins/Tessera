# SecureClaw environment — example / documentation
# Copy to .env and fill in your values, or run: secureclaw init
#
# NEVER commit .env — it is already in .gitignore.

# ── Gateway ──────────────────────────────────────────────────────────────────
# 64-character hex string. Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
GATEWAY_HMAC_SECRET=change-me-generate-with-secureclaw-init

# ── Credential vault (AES-256-GCM encrypted-file fallback) ──────────────────
# Used only when keytar (OS keychain) is unavailable (headless Linux / WSL / CI).
VAULT_MASTER_KEY=change-me-generate-with-secureclaw-init

# ── LLM provider ─────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-6

# Ollama (local, no API key required)
# OLLAMA_BASE_URL=http://127.0.0.1:11434

# ── Optional overrides (defaults shown) ──────────────────────────────────────
# GATEWAY_PORT=18789
# GATEWAY_HOST=127.0.0.1
# AUDIT_DATA_DIR=/tmp/secureclaw-audit
# VAULT_DATA_DIR=/tmp/secureclaw-vault
# MEMORY_DATA_DIR=/data/memory
# SKILLS_REGISTRY_PATH=/tmp/secureclaw-skills-registry.json
# MARKETPLACE_REGISTRY_PATH=/tmp/secureclaw-marketplace-registry.json
# AUDIT_COST_CAP_USD=5.0
